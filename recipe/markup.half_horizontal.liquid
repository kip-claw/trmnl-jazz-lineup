<div class="layout layout--col" style="height: 100%;">
{% assign shown_count = 0 %}
{% for event in events %}{% if event.on_board %}{% assign shown_count = shown_count | plus: 1 %}{% endif %}{% endfor %}
{% assign hh_shown = shown_count %}
{% if hh_shown > 24 %}{% assign hh_shown = 24 %}{% endif %}
{% assign hh_rows = hh_shown | divided_by: 4.0 | ceil %}
{% if hh_rows < 1 %}{% assign hh_rows = 1 %}{% endif %}

{% comment %} Column-major grid scoped here (like the full board) rather than the
Framework grid class, which centers its items. Plain display: grid defaults to
stretch, so entries fill their cells and stay left-aligned. {% endcomment %}
<style>
  .jazz-grid-hh {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat({{ hh_rows }}, 1fr);
    grid-auto-flow: column;
    column-gap: 24px;
    row-gap: 4px;
    flex: 1 1 auto;
    min-height: 0;
    overflow: hidden;
  }
</style>

<div class="flex flex--row flex--align-center flex--between flex-none mb--small">
  <div class="flex flex--row flex--align-center gap--small">
    <span class="title title--small">JazzLineup.com NYC</span>
    <span class="description description--small">{{ today | date: "%A, %B %-d" }}</span>
  </div>
  <span class="label label--small label--inverted">{{ shown_count }} SHOWS</span>
</div>

{% if shown_count > 0 %}
<div class="jazz-grid-hh">
  {% assign n = 0 %}
  {% for event in events %}
    {% if event.on_board %}
      {% if n < 24 %}
      <div class="flex flex--row flex--align-center gap--xsmall" style="min-width: 0;">
        <span class="label label--small flex-none" style="width: 32px;">{{ event.sets.first | default: "TBA" }}</span>
        <span class="description description--small grow" style="font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; min-width: 0;">{{ event.title }}</span>
      </div>
      {% endif %}
      {% assign n = n | plus: 1 %}
    {% endif %}
  {% endfor %}
</div>
{% else %}
<div class="center-center grow">
  <div class="description">No listed sets tonight — check Jazz Lineup for changes.</div>
</div>
{% endif %}
</div>
