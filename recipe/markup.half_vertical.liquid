<div class="layout layout--col" style="height: 100%;">
{% assign shown_count = 0 %}
{% for event in events %}{% if event.on_board %}{% assign shown_count = shown_count | plus: 1 %}{% endif %}{% endfor %}

<div class="flex flex--row flex--align-center flex--between flex-none mb--small">
  <span class="title title--small">JazzLineup.com NYC</span>
  <span class="label label--small label--inverted">{{ shown_count }}</span>
</div>

{% if shown_count > 0 %}
<div class="flex flex--col grow gap--small" style="min-height: 0; overflow: hidden;">
  {% assign n = 0 %}
  {% for event in events %}
    {% if event.on_board %}
      {% if n < 10 %}
      <div class="flex flex--row flex--align-center gap--xsmall" style="min-width: 0;">
        <span class="label label--small flex-none" style="width: 32px;">{{ event.sets.first | default: "TBA" }}</span>
        <div class="flex flex--col grow" style="min-width: 0;">
          <span class="description description--small clamp--1" style="font-weight: 700;">{{ event.title }}</span>
          <span class="description description--small clamp--1">{{ event.venue }}</span>
        </div>
      </div>
      {% endif %}
      {% assign n = n | plus: 1 %}
    {% endif %}
  {% endfor %}
  {% if shown_count > 10 %}
  <span class="label label--small">+{{ shown_count | minus: 10 }} more at JazzLineup.com</span>
  {% endif %}
</div>
{% else %}
<div class="center-center grow">
  <div>
    <div class="title title--small">No listed sets tonight</div>
    <div class="description description--small">Check Jazz Lineup for changes.</div>
  </div>
</div>
{% endif %}
</div>
