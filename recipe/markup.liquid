{% assign shown_count = 0 %}
{% for event in events %}{% if event.on_board %}{% assign shown_count = shown_count | plus: 1 %}{% endif %}{% endfor %}
{% assign row_count = shown_count | divided_by: 4.0 | ceil %}
{% assign row_count_portrait = shown_count | divided_by: 2.0 | ceil %}

{% comment %} Column-major grid: 4 columns in landscape, 2 in portrait. Framework
grid--cols-* is row-major and would scramble the chronological down-each-column
order, so the grid template is scoped here and keyed off TRMNL's .screen--portrait
class. Utility classes move the class-less values (fixed time column, flex
truncation) out of inline styles. {% endcomment %}
<style>
  .jazz-min-w-0 { min-width: 0; }
  .jazz-trunc { min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .jazz-time { width: 32px; }
  .jazz-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat({{ row_count }}, 1fr);
    grid-auto-flow: column;
    column-gap: 24px;
    row-gap: 6px;
    flex: 1 1 auto;
    min-height: 0;
  }
  .screen--portrait .jazz-grid {
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat({{ row_count_portrait }}, 1fr);
  }
</style>

<div class="title_bar">
  <img class="image" src="https://raw.githubusercontent.com/kip-claw/trmnl-jazz-lineup/main/docs/jazzlineup-favicon-eink.png" />
  <span class="title">JazzLineup.com NYC</span>
  <span class="instance">{{ today | date: "%A, %B %-d" }} · {{ shown_count }} shows</span>
</div>

<div class="layout layout--col">
{% if shown_count > 0 %}
<div class="jazz-grid">
  {% for event in events %}
    {% if event.on_board %}
    <div class="flex flex--row flex--align-center gap--xsmall jazz-min-w-0">
      <span class="label label--small flex-none jazz-time">{{ event.sets.first | default: "TBA" }}</span>
      <div class="grow jazz-min-w-0">
        <div class="description description--small text--bold jazz-trunc">{{ event.title }}</div>
        <div class="description description--small jazz-trunc">{{ event.venue }}</div>
      </div>
    </div>
    {% endif %}
  {% endfor %}
</div>
{% else %}
<div class="center-center grow">
  <div>
    <div class="title title--small">No listed sets tonight</div>
    <div class="description description--small">Check Jazz Lineup for changes.</div>
  </div>
</div>
{% endif %}
</div>
