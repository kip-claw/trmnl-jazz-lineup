<div class="layout layout--col" style="height: 100%;">
{% assign shown_count = 0 %}
{% for event in events %}
  {% if event.on_board %}
    {% assign shown_count = shown_count | plus: 1 %}
  {% endif %}
{% endfor %}
{% assign row_count = shown_count | divided_by: 4.0 | ceil %}

<div class="flex flex--row flex--align-center" style="flex: none; margin-bottom: 4px; justify-content: space-between; width: 100%;">
  <div class="flex flex--row flex--align-center gap--small">
    <span class="title title--small">JazzLineup.com NYC</span>
    <span class="description description--small">{{ today | date: "%A, %B %-d" }}</span>
  </div>
  <span class="label label--small label--inverted">{{ shown_count }} SHOWS</span>
</div>

{% if shown_count > 0 %}
<div class="grid" style="grid-template-columns: repeat(4, 1fr); grid-template-rows: repeat({{ row_count }}, 1fr); grid-auto-flow: column; column-gap: 24px; row-gap: 6px; flex: 1 1 auto; min-height: 0;">
  {% for event in events %}
    {% if event.on_board %}
    <div class="item" style="min-width: 0; display: flex; flex-direction: column; justify-content: center;">
      <div class="flex flex--row flex--align-center" style="min-width: 0; gap: 4px;">
        <span class="label label--small" style="width: 32px; flex: none;">{{ event.sets.first | default: "TBA" }}</span>
        <span class="description description--small" style="font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; min-width: 0; flex: 1 1 auto;">{{ event.title }}</span>
      </div>
      <div class="description description--small" style="padding-left: 36px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{ event.venue }}</div>
    </div>
    {% endif %}
  {% endfor %}
</div>
{% else %}
<div class="center-center" style="flex: 1 1 auto;">
  <div>
    <div class="title">No listed sets tonight</div>
    <div class="description">Check Jazz Lineup for changes.</div>
  </div>
</div>
{% endif %}
</div>
