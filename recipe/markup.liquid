<div class="layout layout--col gap--space-between">
  {% assign favorite_venues = trmnl.plugin_settings.custom_fields_values.favorite_venues %}
  {% assign shown_count = 0 %}
  {% for event in events %}
    {% if event.date == today %}
      {% if favorite_venues == blank or favorite_venues contains event.venue_id %}
        {% assign shown_count = shown_count | plus: 1 %}
      {% endif %}
    {% endif %}
  {% endfor %}

  <div class="flex flex--row flex--align-center gap--small">
    <span class="title title--small">NYC JAZZ TONIGHT</span>
    <span class="label label--small label--inverted">{{ shown_count }} SHOWS</span>
    <span class="description description--small">{{ today | date: "%A, %b %-d" }}</span>
  </div>

  {% if shown_count > 0 %}
    <div class="grid grid--cols-4 gap--xsmall" style="grid-auto-flow: row; align-content: start;">
      {% for event in events %}
        {% if event.date == today %}
          {% if favorite_venues == blank or favorite_venues contains event.venue_id %}
            <div class="item" style="min-width: 0; padding-bottom: 3px;">
              <div class="flex flex--row flex--align-center gap--xsmall">
                <span class="label label--small" style="width: 38px; flex: none;">{{ event.sets.first | default: "TBA" }}</span>
                <span class="description description--small" style="font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{ event.title }}</span>
              </div>
              <div class="description description--small" style="padding-left: 42px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{ event.venue }}</div>
            </div>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
  {% else %}
    <div class="center-center" style="height: 260px">
      <div>
        {% if favorite_venues == blank %}
          <div class="title">No listed sets tonight</div>
          <div class="description">Check Jazz Lineup for changes.</div>
        {% else %}
          <div class="title">No favorite venues tonight</div>
          <div class="description">Edit favorites to see the full citywide listing.</div>
        {% endif %}
      </div>
    </div>
  {% endif %}

  <div class="description description--small">{% if favorite_venues == blank %}All venues{% else %}Favorite venues{% endif %} · Data: Jazz Lineup · Updated {{ generated_at | date: "%l:%M %p" }}</div>
</div>
