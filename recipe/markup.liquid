<div class="layout layout--col" style="height: 100%;">
{% assign shown_count = 0 %}
{% for event in events %}{% if event.on_board %}{% assign shown_count = shown_count | plus: 1 %}{% endif %}{% endfor %}
{% assign row_count = shown_count | divided_by: 4.0 | ceil %}
{% assign row_count_portrait = shown_count | divided_by: 2.0 | ceil %}

{% comment %} Column-major grid: 4 columns in landscape, 2 in portrait. Framework
grid--cols-* is row-major and would scramble the chronological down-each-column
order, so the grid template is scoped here and keyed off TRMNL's .screen--portrait
class. Remaining inline styles are limited to properties with no Framework class
(the dynamic grid template, the fixed time-column width, bold weight, and
single-line truncation). {% endcomment %}
<style>
  .jazz-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat({{ row_count }}, 1fr);
    grid-auto-flow: column;
    column-gap: 24px;
    row-gap: 6px;
    flex: 1 1 auto;
    min-height: 0;
  }
  .screen--portrait .jazz-grid {
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat({{ row_count_portrait }}, 1fr);
  }
</style>

<div class="flex flex--row flex--align-center flex--between flex-none mb--small" style="width: 100%;">
  <div class="flex flex--row flex--align-center gap--small">
    <span class="title title--small">JazzLineup.com NYC</span>
    <span class="description description--small">{{ today | date: "%A, %B %-d" }}</span>
  </div>
  <span class="label label--small label--inverted">{{ shown_count }} SHOWS</span>
</div>

{% if shown_count > 0 %}
<div class="jazz-grid">
  {% for event in events %}
    {% if event.on_board %}
    <div class="flex flex--row flex--align-center gap--xsmall" style="min-width: 0;">
      <span class="label label--small flex-none" style="width: 32px;">{{ event.sets.first | default: "TBA" }}</span>
      <div class="grow" style="min-width: 0;">
        <div class="description description--small" style="font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{ event.title }}</div>
        <div class="description description--small" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{ event.venue }}</div>
      </div>
    </div>
    {% endif %}
  {% endfor %}
</div>
{% else %}
<div class="center-center grow">
  <div>
    <div class="title">No listed sets tonight</div>
    <div class="description">Check Jazz Lineup for changes.</div>
  </div>
</div>
{% endif %}
</div>
